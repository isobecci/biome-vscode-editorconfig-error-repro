# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
max_line_length = 80
tab_width = 2
trim_trailing_whitespace = true

[*.{json,jsonc,toml,yaml,yml}]
indent_style = space
insert_final_newline = false # ← causes problems with biome-vscode

[*.md]
indent_style = space
trim_trailing_whitespace = false
